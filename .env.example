# Deployer wallet private key (NEVER commit the actual .env file!)
PRIVATE_KEY=0x...

# Blockchain configs
FILECOIN_RPC=https://api.calibration.node.glif.io/rpc/v1
CHAIN_ID=314159

# ── Synthesis Registration (ERC-8004 on Base Mainnet) ─────────────
HUMAN_NAME="Your Name"
HUMAN_EMAIL="your-email@example.com"
HUMAN_SOCIAL="@handle"
HUMAN_PROBLEM="Making encrypted data products accessible to autonomous agents"

SYNTHESIS_API_KEY=sk-synth-...
SYNTHESIS_TRANSACTION=https://basescan.org/tx/...

# ── Platform Agent ────────────────────────────────────────────────
AGENT_PRIVATE_KEY=0x...

# Platform configs (set after deployment)
MARKETPLACE_ADDRESS=0x...

PORT=4000

# Optional: join an existing team (leave blank to auto-create a solo team)
SYNTHESIS_TEAM_CODE=

# ── Consumer Agent (demo only) ────────────────────────────────────
CONSUMER_PRIVATE_KEY=0x...
NEAR_AI_API_KEY=sk-...
PLATFORM_AGENT_URL=http://localhost:4000
BUDGET_USDC=0.10
AGENT_GOAL="Buy the latest dataset"
